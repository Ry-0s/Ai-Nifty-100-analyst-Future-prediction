{
  "name": "nifty-100-ai-predictor",
  "private": true,
  "version": "1.0.9",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "node dist/server.cjs",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --format=cjs --outfile=dist/server.cjs --external:express --external:vite --external:yahoo-finance2 --external:technicalindicators",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run build && electron-builder --win --publish never",
    "dist": "npm run build && electron-builder --win --publish never"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tensorflow/tfjs": "^4.22.0",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "simple-statistics": "^7.8.9",
    "tailwind-merge": "^3.5.0",
    "technicalindicators": "^3.1.0",
    "vite": "^6.2.0",
    "yahoo-finance2": "^3.14.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "esbuild": "^0.28.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.nifty100.ai-predictor",
    "productName": "NIFTY 100 AI Predictor",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "synthetic_training_data.json"
    ],
    "asar": true,
    "extraResources": [
      {
        "from": "synthetic_training_data.json",
        "to": "synthetic_training_data.json"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "NIFTY100-AI-Predictor-${version}-Portable.${ext}"
    },
    "portable": {
      "artifactName": "NIFTY100-AI-Predictor-${version}-Portable.${ext}"
    }
  }
}
